# Claude Code .gitignore

# Node modules (if you add any scripts)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.*
!.env.example

# API keys
*.key
*credentials.json
*secret*

# Logs
*.log
debug/

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Backup files
*.backup
*.backup.*
*.bak

# Local overrides (if user wants to customize without committing)
settings.local.json
CLAUDE.local.md
