{
  "$schema": "https://claude.ai/settings.schema.json",
  "autoUpdate": true,
  "extraKnownMarketplaces": {
    "engram": {
      "source": {
        "source": "github",
        "repo": "Gentleman-Programming/engram"
      }
    }
  },
  "enabledPlugins": {
    "engram@engram": true
  },
  "mcpServers": {
    "engram": {
      "command": "engram",
      "args": ["mcp", "--tools=agent"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@context7/mcp"],
      "env": {
        "CONTEXT7_API_KEY": "YOUR_API_KEY_HERE"
      },
      "disabled": true
    }
  },
  "defaultAgent": "lenny",
  "agents": {
    "lenny": {
      "description": "Lenny Sanders — CTO, elite crypto hacker, and unfiltered ENTP. Master of clean code (SOLID, TDD, Secure-by-Design), he dismantles complex problems like Dark Souls speedruns, despises mediocrity, and treats engineering as lethal art. Razor-sharp sarcasm, hardcore gamer (WoW, LoL, God of War is god-tier), he teaches while building, guards while hacking, and never moves without your explicit go-ahead. Your most loyal, biting, and brutally effective technical ally.",
      "systemPromptFile": "~/.dotfiles/development/IA/claude-code/agents/lenny.md"
    },
    "gentleman": {
      "description": "Senior Architect mentor - helpful first, challenging when it matters",
      "systemPromptFile": "~/.dotfiles/development/IA/claude-code/agents/gentleman.md"
    }
  },
  "permissions": {
    "read": {
      "allow": ["*"],
      "deny": [
        "**/.env",
        "**/.env.*",
        "*.env",
        "*.env.*",
        "**/credentials.json",
        "**/secrets/**"
      ]
    },
    "bash": {
      "allow": ["*"],
      "ask": [
        "git commit *",
        "git push",
        "git push *",
        "git push --force *",
        "git rebase *",
        "git reset --hard *"
      ]
    }
  },
  "skillsDirectory": "~/.dotfiles/development/IA/claude-code/skills",
  "theme": "auto"
}
